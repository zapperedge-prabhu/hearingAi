# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/database_name

# JWT Secret for authentication (generate a strong secret for production)
ZAPPER_JWT_SECRET=your-secure-jwt-secret-here

# Azure Key Vault (optional - for production environments)
ZAPPER_USE_KEYVAULT=false
KEY_VAULT_URL=https://your-vault.vault.azure.net/
DB_SECRET_NAME=DatabaseUrl

# File Upload Configuration
ZAPPER_FILE_UPLOAD_MODE=memory
ZAPPER_MEMORY_UPLOAD_LIMIT_MB=100
ZAPPER_UPLOAD_DIR=/tmp/uploads
ZAPPER_CHUNK_SIZE_MB=4
ZAPPER_UPLOAD_CONCURRENCY=5
ZAPPER_MAX_RETRIES=3

# Upload Limits
# Maximum number of files that can be uploaded in a single operation
ZAPPER_MAX_FILES_COUNT=1000
# Maximum total upload size in GB (e.g., 15 means 15GB)
ZAPPER_MAX_UPLOAD_SIZE=15

# Zip and Download Configuration
ZAPPER_ZIP_STRATEGY_THRESHOLD_MB=100
ZAPPER_USE_ACA_FOR_DOWNLOADS=false

# Initial User Setup (optional)
ZAPPER_INITIAL_USER=admin@example.com
ZAPPER_INITIAL_SUPER_ORG_NAME=Default Organization

# Azure Configuration (for production)
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_RESOURCE_GROUP=your-resource-group

# Microsoft Defender for Storage - HNS Mode Configuration
# Set to TRUE for ADLS Gen2/Hierarchical Namespace storage accounts
# When enabled: Uses Event Grid webhook + custom blob tags (zapper_scan_result)
# When disabled: Uses native Defender blob tags (Malware Scanning scan result)
# Default: FALSE (uses native Defender tags for regular Blob Storage)
ZAPPER_HNS_FLAG=FALSE

# MSAL runtime configuration
ZAPPER_MSAL_CLIENT_ID=
ZAPPER_MSAL_AUTHORITY=
ZAPPER_MSAL_KNOWN_AUTHORITIES=zapperedge.ciamlogin.com
ZAPPER_REDIRECT_URI=
ZAPPER_MSAL_CACHE_LOCATION=sessionStorage
ZAPPER_MSAL_STORE_AUTHSTATE_COOKIE=false
ZAPPER_MSAL_LOGLEVEL=Error

# Optional: domain hint for login (e.g. contoso.onmicrosoft.com). Leave empty to omit.
ZAPPER_DOMAIN_HINT=

# ================================================================================
# ACTIVITY LOGGING CONFIGURATION
# ================================================================================
# Control which activities are logged to the database
# Set to 'true' to enable logging, 'false' to disable
# This allows customization per customer installation

# AUTHENTICATION ACTIVITY LOGS
ZAPPER_LOG_LOGIN=true
ZAPPER_LOG_LOGOUT=true
ZAPPER_LOG_LOGIN_FAILED=true

# FILE MANAGEMENT ACTIVITY LOGS
ZAPPER_LOG_UPLOAD_FILE=true
ZAPPER_LOG_DOWNLOAD_FILE=true
ZAPPER_LOG_DELETE_FILE=true
ZAPPER_LOG_CREATE_DIRECTORY=true
ZAPPER_LOG_DELETE_DIRECTORY=true
ZAPPER_LOG_DOWNLOAD_DIRECTORY=true
ZAPPER_LOG_VIEW_FILES=true
ZAPPER_LOG_PREVIEW_FILE=true

# STORAGE MANAGEMENT ACTIVITY LOGS
ZAPPER_LOG_CREATE_STORAGE_ACCOUNT=true
ZAPPER_LOG_DELETE_STORAGE_ACCOUNT=true
ZAPPER_LOG_VIEW_STORAGE_ACCOUNTS=true
ZAPPER_LOG_CREATE_CONTAINER=true
ZAPPER_LOG_CONFIGURE_CORS=true
ZAPPER_LOG_CONFIGURE_DATA_PROTECTION=true
ZAPPER_LOG_VIEW_DATA_PROTECTION_STATUS=true
ZAPPER_LOG_CONFIGURE_DATA_LIFECYCLE=true
ZAPPER_LOG_VIEW_DATA_LIFECYCLE_RULES=true
ZAPPER_LOG_DELETE_DATA_LIFECYCLE_RULE=true
ZAPPER_LOG_ENABLE_SFTP=true
ZAPPER_LOG_DISABLE_SFTP=true
ZAPPER_LOG_VIEW_SFTP_STATUS=true
ZAPPER_LOG_ASSIGN_STORAGE_ROLE=true

# USER MANAGEMENT ACTIVITY LOGS
ZAPPER_LOG_CREATE_USER=true
ZAPPER_LOG_UPDATE_USER=true
ZAPPER_LOG_DELETE_USER=true
ZAPPER_LOG_VIEW_USERS=true
ZAPPER_LOG_ENABLE_USER_ROLE=true
ZAPPER_LOG_DISABLE_USER_ROLE=true
ZAPPER_LOG_DELETE_USER_ROLE=true

# ORGANIZATION MANAGEMENT ACTIVITY LOGS
ZAPPER_LOG_CREATE_ORGANIZATION=true
ZAPPER_LOG_UPDATE_ORGANIZATION=true
ZAPPER_LOG_DELETE_ORGANIZATION=true
ZAPPER_LOG_VIEW_ORGANIZATIONS=true

# ROLE MANAGEMENT ACTIVITY LOGS
ZAPPER_LOG_CREATE_ROLE=true
ZAPPER_LOG_UPDATE_ROLE=true
ZAPPER_LOG_DELETE_ROLE=true
ZAPPER_LOG_VIEW_ROLES=true

# AI AGENT MANAGEMENT ACTIVITY LOGS
ZAPPER_LOG_CREATE_AI_AGENT=true
ZAPPER_LOG_UPDATE_AI_AGENT=true
ZAPPER_LOG_DELETE_AI_AGENT=true
ZAPPER_LOG_VIEW_AI_AGENTS=true
ZAPPER_LOG_RUN_AI_AGENT=true